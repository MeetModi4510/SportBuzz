{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://sportbuzz-backend.onrender.com/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://sportbuzz-backend.onrender.com/socket.io/:path*"
    },
    {
      "source": "/((?!api|socket\\.io|assets|images|favicon).*)",
      "destination": "/index.html"
    }
  ]
}
